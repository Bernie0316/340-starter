<% if (title) { %>
    <h1><%= title %></h1>
<% } else {
    res.redirect('/')
} %>
    
<%- messages() %>
    
<form id="loginForm" action="/account/login" method="post">
    <fieldset class="form">
        <label for="email">Email Address:
            <input type="email" name="email" id="email" required placeholder="Enter your email">
        </label>
        <label for="password">Password:
            <input type="password" name="password" id="password" required placeholder="Enter your password">
        </label>
        <p>Password must be minimum of 12 characters and include 1 capital letter, 1 number and 1 special character</p>
        <button type="submit" class="showPassword-btn">Show Password</button>
        <button type="submit" class="submit-btn">Login</button>
    </fieldset>
    <div id="registerArea">
        <p>Don't have an account? <a href="/account/register">Register here</a></p>
    </div>
</form>